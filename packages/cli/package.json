{
  "name": "@feature-flags/cli",
  "version": "0.1.0",
  "description": "CLI to manage local .featureflags.json",
  "type": "module",
  "bin": {
    "feature": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@feature-flags/core": "workspace:*",
    "chalk": "^5.4.1",
    "commander": "^13.1.0"
  },
  "keywords": ["feature-flags", "cli"],
  "license": "MIT"
}
