{
  "name": "feature-flags-core",
  "version": "0.1.1",
  "description": "Core storage, evaluation, and remote fetch for feature flags",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./store": {
      "types": "./dist/store.d.ts",
      "import": "./dist/store.js"
    },
    "./evaluator": {
      "types": "./dist/evaluator.d.ts",
      "import": "./dist/evaluator.js"
    },
    "./remote": {
      "types": "./dist/remote.d.ts",
      "import": "./dist/remote.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "feature-flags",
    "feature-toggles"
  ],
  "license": "MIT"
}
