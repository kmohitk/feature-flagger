{
  "name": "feature-flags",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm --filter @feature-flags/core build && pnpm --filter @feature-flags/cli build && pnpm --filter @feature-flags/sdk build",
    "dev": "pnpm -r --parallel run dev",
    "clean": "pnpm -r exec rm -rf dist",
    "example:react": "pnpm --filter example-react-app dev",
    "example:node": "pnpm --filter example-node-app start"
  },
  "engines": {
    "node": ">=18"
  }
}
